# ── Telegram ──────────────────────────────────────────────────────────────
# Bot token from @BotFather (looks like 123456789:AAH...).
TELEGRAM_BOT_TOKEN=

# Where new order notifications are sent. Your personal chat id, or a group/
# channel id (groups/channels start with -100...). Find it via @userinfobot
# or @getidsbot.
TELEGRAM_CHAT_ID=

# A long random string. The same value is registered with Telegram when you set
# the webhook, and is checked on every incoming webhook call. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=

# ── Site ─────────────────────────────────────────────────────────────────
# Public URL of the deployed site, no trailing slash. Used for SEO
# (canonical URLs, hreflang, sitemap) and to register the Telegram webhook.
NEXT_PUBLIC_SITE_URL=https://your-domain.example
